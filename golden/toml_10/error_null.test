// This test tests both that serializing `null` is an error,
// and that the context of the error is reported properly.
{
  outer = {
    inner = [
      "first",
      null,
      "last",
    ]
  }
}

# output:
stdin:3:1
  ╷
3 │ {
  ╵ ^
in value
at key "outer"
at key "inner"
at index 1
Error: Null cannot be exported as TOML.
